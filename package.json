{
  "name": "pastevault",
  "version": "0.1.6",
  "description": "Secure end-to-end encrypted paste sharing",
  "main": "dist/index.js",
  "bin": {
    "pastevault": "dist/cli.js"
  },
  "files": [
    "dist/",
    "frontend/.next/",
    "frontend/public/",
    "frontend/next.config.js",
    "frontend/package.json",
    "prisma/",
    "scripts/"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:cli": "npm run build && npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "start": "node dist/index.js",
    "db:push": "node scripts/prisma-runner.mjs db push",
    "db:migrate": "node scripts/prisma-runner.mjs migrate dev",
    "db:generate": "node scripts/prisma-runner.mjs generate",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build:cli",
    "postinstall": "prisma generate --schema=prisma/schema.prisma"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arc53/pastevault.git"
  },
  "homepage": "https://pastevault.dev/",
  "bugs": {
    "url": "https://github.com/arc53/pastevault/issues"
  },
  "keywords": [
    "paste",
    "pastebin",
    "secure",
    "encryption",
    "e2ee",
    "zero-knowledge",
    "cli",
    "self-hosted",
    "markdown",
    "nextjs",
    "fastify",
    "prisma",
    "postgresql",
    "sqlite"
  ],
  "license": "GPL-3.0",
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@monaco-editor/react": "^4.7.0",
    "@noble/ciphers": "^2.0.1",
    "@prisma/client": "^6.18.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.90.6",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.552.0",
    "nanoid": "^5.1.6",
    "next": "^16.0.1",
    "next-intl": "^4.4.0",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "prisma": "^6.18.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "sodium-native": "^5.0.9",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.16",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
